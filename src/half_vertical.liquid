{% unless found %}
<div class="layout gap--xxlarge">
  <div class="grid grid--cols-1">
    {% if team_badge %}
    <div class="row row--center">
      <div class="flex flex--col no-shrink">
        <img class="image-dither w--40 lg:w--60" src="{{ team_badge }}"{% if team_badge_invert %} style="filter: invert(1);"{% endif %}>
      </div>
    </div>
    {% endif %}
    <div class="row row--center">
      <div class="flex flex--col no-shrink">
        <span class="value lg:value--large">{{ not_found_message }}</span>
      </div>
    </div>
  </div>
</div>
{% else %}
<div class="layout gap--xxlarge">
  <div class="grid grid--cols-1">
    <div class="row row--center">
      <div class="flex flex--col gap--xsmall no-shrink">
        <img class="image-dither w--40 lg:w--60" src="{{ away_team_badge }}"{% if away_team_badge_invert %} style="filter: invert(1);"{% endif %}>
      </div>
      <div class="flex flex--col flex--center-y gap--xsmall" style="padding: 0 0.5rem;">
        <span class="value value--small lg:value--xlarge">@</span>
      </div>
      <div class="flex flex--col gap--xsmall no-shrink">
        <img class="image-dither w--40 lg:w--60" src="{{ home_team_badge }}"{% if home_team_badge_invert %} style="filter: invert(1);"{% endif %}>
      </div>
    </div>
    <div class="row row--center">
      <div class="flex flex--col no-shrink">
        {% render "date_time", date_label: date_label, time_label: time_label %}
      </div>
    </div>
  </div>
</div>
{% endunless %}
<div class="title_bar">
  <span class="title">Next Game</span>
  {% if team_name %}<span class="instance">{{ team_name }}</span>{% endif %}
</div>
