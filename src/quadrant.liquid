{% unless found %}
<div class="layout gap--xlarge">
  {% if team_badge %}
  <div class="flex flex--col gap--xsmall no-shrink">
    {% render "badge", src: team_badge, invert: team_badge_invert, trim: team_badge_trim, size_class: "h--16 lg:h--24" %}
  </div>
  {% endif %}
  <div class="flex flex--col no-shrink">
    <span class="value value--small lg:value--base">{{ not_found_message }}</span>
    {% render "stale_note", stale: stale, as_of_label: as_of_label, stale_class: "value value--xxsmall" %}
  </div>
</div>
{% else %}
<div class="layout gap--xlarge">
  <div class="flex flex--col gap--xsmall no-shrink">
    {% render "badge", src: away_team_badge, invert: away_team_badge_invert, trim: away_team_badge_trim, size_class: "h--16 lg:h--24", clamp_aspect: true %}
    <span class="value value--xxsmall lg:value--small">@</span>
    {% render "badge", src: home_team_badge, invert: home_team_badge_invert, trim: home_team_badge_trim, size_class: "h--16 lg:h--24", clamp_aspect: true %}
  </div>
  <div class="flex flex--col">
    {% render "date_time", date_label: date_label, time_label: time_label, date_class: "value value--small lg:value--base", time_class: "value value--small lg:value--base" %}
    {% render "stale_note", stale: stale, as_of_label: as_of_label, stale_class: "value value--xxsmall" %}
  </div>
</div>
{% endunless %}
<div class="title_bar">
  <span class="title">Next Game</span>
  {% if team_name %}<span class="instance">{{ team_name }}</span>{% endif %}
</div>
