{% unless found %}
<div class="layout gap--xlarge">
  {% if team_badge %}
  <div class="flex flex--col gap--xsmall no-shrink">
    <img class="image-dither h--16 lg:h--24" src="{{ team_badge }}"{% if team_badge_invert %} style="filter: invert(1);"{% endif %}>
  </div>
  {% endif %}
  <div class="flex flex--col no-shrink">
    <span class="value value--small lg:value--base">{{ not_found_message }}</span>
  </div>
</div>
{% else %}
<div class="layout gap--xlarge">
  <div class="flex flex--col gap--xsmall no-shrink">
    <img class="image-dither h--16 lg:h--24" src="{{ away_team_badge }}"{% if away_team_badge_invert %} style="filter: invert(1);"{% endif %}>
    <span class="value value--xxsmall lg:value--small">@</span>
    <img class="image-dither h--16 lg:h--24" src="{{ home_team_badge }}"{% if home_team_badge_invert %} style="filter: invert(1);"{% endif %}>
  </div>
  <div class="flex flex--col">
    {% render "date_time", date_label: date_label, time_label: time_label, date_class: "value value--small lg:value--base", time_class: "value value--small lg:value--base" %}
  </div>
</div>
{% endunless %}
<div class="title_bar">
  <span class="title">Next Game</span>
  {% if team_name %}<span class="instance">{{ team_name }}</span>{% endif %}
</div>
