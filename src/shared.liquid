{% template date_time %}
  <span class="{{ date_class | default: 'value lg:value--large' }}">{{ date_label }}</span>
  <span class="{{ time_class | default: 'value lg:value--large' }}">{{ time_label }}</span>
{% endtemplate %}

{% template stale_note %}
  {% if stale %}<span class="{{ stale_class | default: 'value value--xxsmall text--gray-50' }}">{{ as_of_label }}</span>{% endif %}
{% endtemplate %}

{% template badge %}
  {% assign tx = trim.x | default: 0 %}
  {% assign ty = trim.y | default: 0 %}
  {% assign tw = trim.w | default: 1 %}
  {% assign th = trim.h | default: 1 %}
  {% comment %} Wide-logo aspect ceiling (pape-docs/0079): matchup renders pass clamp_aspect:true so a wide mark can't out-area its square/tall neighbor. Single (not-found) badges omit it and stay uncapped — no neighbor to balance against. One source of truth for the value. {% endcomment %}
  {% assign ceil = 100000 %}
  {% if clamp_aspect %}{% assign ceil = 1.2 %}{% endif %}
  {% comment %} Two shrink terms layer under min(): (1) the aspect ceiling above, which caps the logo's effective aspect at `ceil` (width = h × ceil); (2) the width cap — height contains to any w--max-* so a clamped wide logo shrinks in BOTH axes and keeps filling the clip, preserving the 0077 edge-to-edge fit (pape-docs/0078). Each is inert when unset (huge sentinel → min() picks the full h-- height). Both read the framework's own --tn-size-* props, so they stay breakpoint-correct. {% endcomment %}
  <div class="badge-clip {{ size_class }}" style="aspect-ratio: {{ tw }} / {{ th }}; overflow: hidden; height: min(var(--tn-size-h), calc(var(--tn-size-h) * {{ ceil }} * {{ th }} / {{ tw }}), calc(var(--tn-size-w-max, 100000px) * {{ th }} / {{ tw }}));">
    <img class="image-dither" src="{{ src }}" style="width: calc(100% / {{ tw }}); height: auto; max-width: none; max-height: none; display: block; transform: translate(calc({{ tx }} * -100%), calc({{ ty }} * -100%));{% if invert %} filter: invert(1);{% endif %}">
  </div>
{% endtemplate %}
